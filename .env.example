# ─────────────────────────────────────────────────────────────────────────────
# IPL-APS — Configuração de ambiente
# Copie este arquivo para .env e preencha os valores reais
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail / E-mail de ingestão ────────────────────────────────────────────────
# Conta Gmail que recebe os laudos do laboratório
GMAIL_EMAIL=seu_email@gmail.com
# Senha de app do Gmail (não a senha da conta)
# Gerar em: https://myaccount.google.com/apppasswords
GMAIL_SENHA=xxxx_xxxx_xxxx_xxxx
# E-mail remetente do laboratório (para filtrar mensagens)
REMETENTE_LAB=laboratorio@exemplo.com.br

# ── JWT / Segurança ──────────────────────────────────────────────────────────
# Chave secreta para assinar tokens JWT — gerar com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GERE_UMA_CHAVE_SEGURA_AQUI
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=10

# ── Paths ────────────────────────────────────────────────────────────────────
# Diretório raiz com os dados (exames.db, exames/, etc.)
DATA_DIR=/caminho/absoluto/para/os/dados
# Caminho do banco de autenticação (usuários e USFs)
AUTH_DB=/caminho/absoluto/para/auth.db

# ── Admin ────────────────────────────────────────────────────────────────────
# Senha do usuário administrador — definir antes de rodar setup_auth.py
# Mínimo 8 caracteres, incluir maiúsculas, números e símbolos
ADMIN_PASSWORD=DefineUmaSenhaForteAqui
